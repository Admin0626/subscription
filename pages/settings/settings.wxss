/* page.dark 作用域生效 */
page.dark .container {
  background-color: var(--surface);
  color: var(--on-surface);
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--surface);
  color: var(--on-surface);
  padding: 0 16rpx;
  box-sizing: border-box;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  transition: background-color 0.25s ease, color 0.25s ease;
}

/* User Card */
.user-card {
  display: flex;
  align-items: center;
  background-color: var(--surface-container-lowest);
  border-radius: 12px;
  padding: 32rpx;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: var(--surface-container-low);
}

.user-right {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--on-surface);
}

.user-id {
  font-size: 0.75rem;
  color: var(--on-surface-variant);
  margin-top: 4rpx;
}

.arrow {
  font-size: 1.25rem;
  color: var(--on-surface-variant);
  font-weight: 300;
}

.theme-status {
  font-size: 0.875rem;
  color: var(--on-surface-variant);
}

/* Stats Row */
.stats-row {
  display: flex;
  justify-content: space-around;
  background-color: var(--surface-container-lowest);
  padding: 32rpx 0;
  border-radius: 12px;
  margin-bottom: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--on-surface);
}

.stat-label {
  display: block;
  font-size: 0.75rem;
  color: var(--on-surface-variant);
  margin-top: 8rpx;
}

/* List Group */
.list-group {
  background-color: var(--surface-container-lowest);
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1px solid var(--surface-container-low);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background-color: var(--surface-container-low);
}

.item-left {
  display: flex;
  align-items: center;
}

.icon {
  font-size: 1rem;
  margin-right: 16rpx;
}

.item-text {
  font-size: 0.9375rem;
  color: var(--on-surface);
}

.danger-text {
  color: var(--error);
  font-weight: 500;
  font-size: 0.9375rem;
}

.list-item.danger {
  border-bottom: none;
}

/* Footer */
.footer {
  text-align: center;
  color: var(--on-surface-variant);
  font-size: 0.75rem;
  margin-top: 48rpx;
}

.safe-area {
  height: env(safe-area-inset-bottom);
}

/* Picker Modal */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--mask-bg);
  z-index: 100;
}

.picker-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface-container-lowest);
  border-radius: 16rpx 16rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 101;
}

.picker-modal.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1px solid var(--surface-container-low);
}

.picker-cancel {
  color: var(--on-surface-variant);
  font-size: 0.9375rem;
}

.picker-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--on-surface);
}

.picker-confirm {
  color: var(--primary);
  font-size: 0.9375rem;
  font-weight: 500;
}

.picker-body {
  padding: 32rpx;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid var(--surface-container-low);
}

.picker-row:last-child {
  border-bottom: none;
}

.picker-label {
  font-size: 0.9375rem;
  color: var(--on-surface);
}

.picker-value {
  font-size: 0.9375rem;
  color: var(--primary);
}