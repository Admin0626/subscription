.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--surface);
  padding: 0 16rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* Safe Area Top - 导航栏安全区 */
.safe-area-top {
  height: calc(88rpx + env(safe-area-inset-top));
  width: 100%;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 999;
  background-color: rgba(249, 249, 251, 0.85);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
}

/* TopAppBar */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  height: 112rpx;
  background-color: var(--surface);
  opacity: 0.85;
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  box-sizing: border-box;
}

.user-section {
  display: flex;
  align-items: center;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--primary-container);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.settings-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Main Scroll */
.main-scroll {
  flex: 1;
  padding: 160rpx 0 40rpx;
  box-sizing: border-box;
}

/* Header Section */
.header-section {
  margin-bottom: 32rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.header-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--on-surface);
}

.tab-switch {
  display: flex;
  background-color: var(--surface-container-low);
  border-radius: 12px;
  padding: 6rpx;
}

.tab-btn {
  padding: 12rpx 24rpx;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--on-surface-variant);
  border-radius: 8px;
  transition: all 0.2s ease;
}

.tab-btn.active {
  background-color: var(--surface-container-lowest);
  color: var(--on-surface);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.header-date {
  font-size: 0.875rem;
  color: var(--on-surface-variant);
  font-weight: 500;
}

/* Empty State */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: var(--on-surface-variant);
  font-size: 0.875rem;
}

/* Hero Card */
.hero-card {
  background-color: var(--surface-container-lowest);
  border-radius: 12px;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.hero-label {
  display: block;
  font-size: 0.875rem;
  color: var(--on-surface-variant);
  margin-bottom: 8rpx;
}

.hero-content {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.hero-amount {
  font-size: 2rem;
  font-weight: 800;
  color: var(--on-surface);
}

.trend-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background-color: rgba(186, 26, 26, 0.1);
  border-radius: 999rpx;
}

.trend-icon {
  font-size: 0.75rem;
  color: var(--error);
  margin-right: 4rpx;
}

.trend-text {
  font-size: 0.625rem;
  font-weight: 600;
  color: var(--error);
}

/* Section */
.section {
  margin-bottom: 48rpx;
}

.section-title {
  display: block;
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--on-surface);
  margin-bottom: 24rpx;
}

/* Category Card */
.category-card {
  background-color: var(--surface-container-lowest);
  border-radius: 12px;
  padding: 32rpx;
}

.donut-container {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.donut-chart {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  position: relative;
}

.donut-hole {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx;
  height: 100rpx;
  background-color: var(--surface-container-low);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.donut-num {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--on-surface);
}

.donut-label {
  font-size: 0.625rem;
  color: var(--on-surface-variant);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* Legend */
.legend-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.legend-name {
  flex: 1;
  font-size: 0.875rem;
  color: var(--on-surface);
  font-weight: 500;
}

.legend-value {
  font-size: 0.875rem;
  color: var(--on-surface);
  font-weight: 600;
  margin-right: 16rpx;
}

.legend-percent {
  font-size: 0.75rem;
  color: var(--on-surface-variant);
  width: 80rpx;
  text-align: right;
}

/* Top List */
.top-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.top-item {
  display: flex;
  align-items: center;
  background-color: var(--surface-container-lowest);
  border-radius: 12px;
  padding: 24rpx;
}

.top-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  background-color: var(--surface-container-low);
}

.logo-img {
  width: 48rpx;
  height: 48rpx;
  object-fit: contain;
}

.logo-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--on-surface-variant);
}

.top-info {
  flex: 1;
}

.top-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.top-name {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--on-surface);
}

.top-price {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--on-surface);
}

.top-bar-bg {
  width: 100%;
  height: 6rpx;
  background-color: var(--surface-container-low);
  border-radius: 3rpx;
  overflow: hidden;
}

.top-bar-fill {
  height: 100%;
  border-radius: 3rpx;
}

/* Insight Card */
.insight-card {
  background-color: var(--insight-bg);
  border-left: 8rpx solid var(--insight-border);
  border-radius: 12px;
  padding: 24rpx;
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.insight-icon {
  font-size: 1rem;
}

.insight-text {
  flex: 1;
  font-size: 0.75rem;
  color: var(--insight-text);
  font-weight: 500;
  line-height: 1.5;
}

.safe-area {
  height: env(safe-area-inset-bottom);
}