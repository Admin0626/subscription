<view class="container {{pageClass}}" 
  style="{{'--surface:' + (pageClass ? '#121212' : '#f9f9fb') + ';--surface-container-lowest:' + (pageClass ? '#1e1e20' : '#ffffff') + ';--on-surface:' + (pageClass ? '#e8e8e8' : '#1a1c1d') + ';--on-surface-variant:' + (pageClass ? '#98989d' : '#8a8a8a') + ';background-color:' + (pageClass ? '#121212' : '#f9f9fb') + ';color:' + (pageClass ? '#e8e8e8' : '#1a1c1d')}}">
  <scroll-view scroll-y class="main-scroll">
    <!-- Header Section -->
    <view class="header-section {{pageClass}}">
      <view class="header-top">
        <text class="header-title">支出概览</text>
        <view class="tab-switch">
          <view class="tab-btn {{activeTab === 'month' ? 'active' : ''}}" bindtap="switchTab" data-type="month">本月</view>
          <view class="tab-btn {{activeTab === 'year' ? 'active' : ''}}" bindtap="switchTab" data-type="year">本年</view>
        </view>
      </view>
      <text class="header-date">{{currentDate}}</text>
    </view>

    <!-- Empty State -->
    <view wx:if="{{!subscriptions.length}}" class="empty-state">
      <text>暂无订阅数据</text>
    </view>

    <!-- Hero Card -->
    <view wx:else class="hero-card">
      <text class="hero-label">总支出</text>
      <view class="hero-content">
        <text class="hero-amount">¥{{totalSpending}}</text>
        <view wx:if="{{trend && activeTab === 'month'}}" class="trend-badge">
          <text class="trend-icon">↑</text>
          <text class="trend-text">{{trend}}% vs 上月</text>
        </view>
      </view>
    </view>

    <!-- Category Breakdown -->
    <view wx:if="{{subscriptions.length}}" class="section">
      <text class="section-title">按类别</text>
      <view class="category-card">
        <view class="donut-container">
          <view class="donut-chart" style="background: conic-gradient({{donutColors}});">
            <view class="donut-hole">
              <text class="donut-num">{{subscriptions.length}}</text>
              <text class="donut-label">种类</text>
            </view>
          </view>
        </view>
        <!-- Legend -->
        <view class="legend-list">
          <view class="legend-item" wx:for="{{categoryStats}}" wx:key="name">
            <view class="legend-dot" style="background-color: {{item.color}};"></view>
            <text class="legend-name">{{item.name}}</text>
            <text class="legend-value">¥{{item.amount}}</text>
            <text class="legend-percent">{{item.percent}}%</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Top Subscriptions -->
    <view wx:if="{{subscriptions.length}}" class="section">
      <text class="section-title">订阅排行</text>
      <view class="top-list">
        <view class="top-item" wx:for="{{topSubscriptions}}" wx:key="id">
          <view class="top-logo">
            <image wx:if="{{item.logoUrl}}" class="logo-img" src="{{item.logoUrl}}" mode="aspectFit"></image>
            <text wx:else class="logo-text">{{item.initial}}</text>
          </view>
          <view class="top-info">
            <view class="top-name-row">
              <text class="top-name">{{item.name}}</text>
              <text class="top-price">¥{{item.monthly}}/月</text>
            </view>
            <view class="top-bar-bg">
              <view style="width: {{item.percent * 7}}rpx; background: linear-gradient(90deg, {{item.color}} 0%, {{item.colorLight}} 100%); height: 100%; border-radius: 3rpx;"></view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Insight Card -->
    <view wx:if="{{insight}}" class="insight-card">
      <text class="insight-icon">💡</text>
      <text class="insight-text">{{insight}}</text>
    </view>

    <view class="safe-area"></view>
  </scroll-view>
</view>