.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--surface);
  width: 100%;
  box-sizing: border-box;
  padding: 0 16rpx;
}

/* Top Navigation */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  height: 112rpx;
  background-color: var(--surface);
  opacity: 0.85;
  backdrop-filter: blur(30rpx);
}

.nav-spacer {
  width: 96rpx;
}

.nav-title {
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--on-surface);
}

.nav-cancel {
  width: 96rpx;
  text-align: right;
  font-size: 0.875rem;
  font-weight: 400;
  color: var(--on-surface-variant);
}

/* Main Scroll */
.main-scroll {
  flex: 1;
  padding: 136rpx 0 24rpx;
  width: 100%;
  box-sizing: border-box;
}

/* Section */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--on-surface);
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

/* Search Box */
.search-box {
  position: relative;
  display: flex;
  align-items: center;
  background-color: var(--surface-container-low);
  border-radius: 12px;
  height: auto;
  padding: 24rpx;
  transition: all 0.2s ease;
}

.search-box.focused {
  background-color: var(--surface-container-lowest);
  border: 1px solid rgba(0, 109, 51, 0.2);
}

.search-input {
  flex: 1;
  font-size: 1rem;
  color: var(--on-surface);
  background: transparent;
}

.search-input::placeholder {
  color: var(--on-surface-variant);
}

.search-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  font-size: 28rpx;
  color: var(--on-surface-variant);
}

/* Quick Select */
.quick-scroll {
  margin-top: 24rpx;
  width: 100%;
  height: 200rpx;
}

.quick-list {
  display: flex;
  flex-wrap: nowrap;
  gap: 16rpx;
  padding: 8rpx 0;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  padding: 24rpx 16rpx;
  background-color: var(--surface-container-low);
  border-radius: 16px;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.quick-item.selected {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
  transform: scale(1.05);
}

.quick-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-logo-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12px;
  margin-bottom: 12rpx;
}

.quick-initial {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--on-primary);
}

.quick-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--on-surface-variant);
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 140rpx;
}

.quick-item.selected .quick-label {
  color: var(--on-primary);
}

/* Input Row Card */
.input-row {
  background-color: var(--surface-container-lowest);
  border-radius: 12px;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 0.875rem;
  font-weight: 400;
  color: var(--on-surface-variant);
  display: block;
  margin-bottom: 16rpx;
}

/* Cost Input */
.cost-input-wrap {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  background: transparent;
}

.cost-prefix {
  font-size: 1.25rem;
  font-weight: 400;
  color: var(--on-surface-variant);
  margin-right: 8rpx;
  vertical-align: middle;
}

.cost-input {
  flex: 1;
  width: auto;
  text-align: left;
  font-size: 1.75rem;
  font-weight: 600;
  color: var(--on-surface);
  font-family: 'SF Mono', 'Menlo', 'Monaco', monospace;
  line-height: 1.2;
  background: transparent;
}

.cost-input::placeholder {
  color: var(--on-surface-variant);
}

/* Segmented Control */
.cycle-row {
  display: flex;
  flex-direction: column;
}

.cycle-picker-container {
  display: flex;
  width: 100%;
  background-color: var(--surface-container-low);
  border-radius: 12px;
  padding: 8rpx;
  margin-top: 16rpx;
}

.cycle-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--on-surface-variant);
  background: transparent;
  border-radius: 8px;
  transition: all 0.2s ease;
}

.cycle-picker.active {
  background-color: var(--surface-container-lowest);
  color: var(--primary);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* Date Picker */
.date-row {
  display: flex;
  flex-direction: column;
}

.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: transparent;
  height: 88rpx;
  border-bottom: 1px solid var(--outline-variant);
}

.date-label {
  font-size: 1rem;
  color: var(--on-surface);
  display: block;
  margin-bottom: 8rpx;
}

.date-value {
  font-size: 1rem;
  font-weight: 400;
  color: var(--on-surface);
}

.date-picker .arrow {
  font-size: 1.2rem;
  color: var(--on-surface-variant);
}

/* Toggle Row */
.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.toggle-info {
  display: flex;
  flex-direction: column;
}

.toggle-label {
  font-size: 1rem;
  font-weight: 400;
  color: var(--on-surface);
}

.toggle-hint {
  font-size: 0.75rem;
  color: var(--on-surface-variant);
  margin-top: 4rpx;
}

.toggle-switch {
  transform: scale(0.9);
}

/* Action Area */
.action-area {
  padding-top: 48rpx;
}

.btn-save {
  width: calc(100% - 32rpx);
  margin: 24rpx 16rpx calc(24rpx + env(safe-area-inset-bottom));
  height: 96rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  font-weight: 600;
  color: var(--on-primary);
  box-shadow: 0 8rpx 24rpx rgba(0, 109, 51, 0.15);
  border: none;
  transition: all 0.2s ease;
}

.btn-save:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.secure-note {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: rgba(138, 138, 138, 0.3);
  margin-top: 32rpx;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  font-weight: 500;
}

/* Picker Mask */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.safe-area {
  height: env(safe-area-inset-bottom);
}