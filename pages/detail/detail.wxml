<view class="container {{pageClass}}" 
  style="{{'--surface:' + (pageClass ? '#121212' : '#f9f9fb') + ';--surface-container-lowest:' + (pageClass ? '#1e1e20' : '#ffffff') + ';--on-surface:' + (pageClass ? '#e8e8e8' : '#1a1c1d') + ';--on-surface-variant:' + (pageClass ? '#98989d' : '#8a8a8a') + ';background-color:' + (pageClass ? '#121212' : '#f9f9fb') + ';color:' + (pageClass ? '#e8e8e8' : '#1a1c1d')}}">

  <scroll-view scroll-y class="main-scroll">
    <!-- Header Section -->
    <view class="header">
      <image class="service-logo" src="{{subscription.logoUrl}}" mode="aspectFit" wx:if="{{subscription.logoUrl}}"></image>
      <view class="service-logo" style="background-color: {{subscription.logoBg}}" wx:else>
        <text class="logo-text">{{subscription.name[0]}}</text>
      </view>
      <text class="service-name">{{subscription.name}}</text>
      <view class="status-tag">生效中</view>
    </view>

    <!-- Info Grid -->
    <view class="info-grid">
      <view class="info-card">
        <text class="info-label">价格</text>
        <text class="info-value primary">¥{{subscription.price}}<text class="info-unit">/月</text></text>
      </view>
      <view class="info-card">
        <text class="info-label">付费周期</text>
        <text class="info-value">{{subscription.cycle === 'monthly' ? '月度' : '年度'}}</text>
        <text class="info-unit">{{subscription.duration}} 天</text>
      </view>
      <view class="info-card highlight">
        <text class="info-label">下次续费</text>
        <text class="info-value primary">{{nextDate}}</text>
      </view>
      <view class="info-card">
        <text class="info-label">首次扣费</text>
        <text class="info-value">{{subscription.startDate}}</text>
      </view>
    </view>

    <!-- Progress Section -->
    <view class="progress-section">
      <view class="progress-header">
        <text class="progress-label">当前周期</text>
        <text class="progress-text">{{daysUsed}}/{{subscription.duration}} 天</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent * 6.9}}rpx; display: block;"></view>
      </view>
      <view class="progress-meta">
        <text class="meta-item">周期起始: {{currentCycleStart}}</text>
        <text class="meta-item">累计已花: ¥{{totalSpent}}</text>
      </view>
    </view>

    <!-- Payment History -->
    <view class="history-section">
      <view class="history-header">
        <text class="history-title">扣费记录</text>
        <text class="history-more" wx:if="{{hasMoreHistory}}" bindtap="onToggleHistory">{{showAllHistory ? '收起' : '查看全部'}}</text>
      </view>
      <view class="history-list">
        <view class="history-item" wx:for="{{displayHistory}}" wx:key="index">
          <view class="history-left">
            <view class="history-icon">
              <text>📅</text>
            </view>
            <view class="history-info">
              <text class="history-date">{{item.date}}</text>
              <view class="history-status">
                <view class="status-dot"></view>
                <text class="history-status-text">已支付</text>
              </view>
            </view>
          </view>
          <text class="history-price">¥{{item.price}}</text>
        </view>
        <view class="history-empty" wx:if="{{paymentHistory.length === 0}}">
          <text>暂无扣费记录</text>
        </view>
      </view>
    </view>

    <!-- Reminder Toggle -->
    <view class="reminder-row">
      <view class="reminder-left">
        <text class="reminder-icon">🔔</text>
        <text class="reminder-text">自动续费提醒</text>
      </view>
      <switch class="toggle-switch" checked="{{subscription.reminder}}" color="var(--primary-container)"/>
    </view>

    <!-- Action Buttons -->
    <view class="action-area">
      <view class="btn-edit" bindtap="onEdit">编辑订阅</view>
      <view class="btn-delete" bindtap="onDelete">取消订阅</view>
    </view>

    <view class="safe-area"></view>
  </scroll-view>
</view>