/* The Fluid Minimalist Design System - Theme Variables */

page {
  --surface: #f9f9fb;
  --surface-container-low: #f3f3f5;
  --surface-container-lowest: #ffffff;
  --surface-container: #eeeef0;
  --surface-container-high: #e8e8ea;
  --on-surface: #1a1c1d;
  --on-surface-variant: #8a8a8a;
  --primary: #006d33;
  --primary-container: #07c160;
  --on-primary: #ffffff;
  --secondary: #2f6a3f;
  --secondary-container: #b1f2bb;
  --tertiary: #a23d33;
  --tertiary-container: #ff8475;
  --error: #ba1a1a;
  --error-container: #ffdad6;
  --outline: #6c7b6c;
  --outline-variant: rgba(26, 28, 29, 0.15);
  --insight-bg: #FFF9E6;
  --insight-border: #FFD54F;
  --insight-text: #7F6000;
  --mask-bg: rgba(0, 0, 0, 0.5);
  --accent-gradient: linear-gradient(135deg, #006d33 0%, #07c160 100%);
  --segment-inactive-bg: #f0f0f0;
  --segment-inactive-text: #8e8e93;
  background-color: var(--surface);
  color: var(--on-surface);
  transition: background-color 0.25s ease, color 0.25s ease;
}

page.dark {
  --surface: #121212;
  --surface-container-low: #2c2c2e;
  --surface-container-lowest: #1e1e20;
  --surface-container: #232426;
  --surface-container-high: #2a2a2d;
  --on-surface: #e8e8e8;
  --on-surface-variant: #98989d;
  --primary: #00c853;
  --primary-container: #004d24;
  --on-primary: #000000;
  --secondary: #4cd964;
  --secondary-container: #003d16;
  --tertiary: #ff6b6b;
  --tertiary-container: #5d1f1f;
  --error: #ff6b6b;
  --error-container: #5d1f1f;
  --outline: #5c5c5c;
  --outline-variant: rgba(255, 255, 255, 0.1);
  --insight-bg: rgba(255, 221, 0, 0.15);
  --insight-border: #b8860b;
  --insight-text: #ffd54f;
  --mask-bg: rgba(0, 0, 0, 0.7);
  --accent-gradient: linear-gradient(135deg, #004d24 0%, #00c853 100%);
  --segment-inactive-bg: #1a1a1a;
  --segment-inactive-text: #98989d;
  background-color: #121212;
}

page.dark .container {
  background-color: #121212;
  color: #e8e8e8;
}

/* Dark mode - index page top nav */
page.dark .top-nav {
  background-color: #121212;
  color: #e8e8e8;
}

page.dark .nav-title {
  color: #e8e8e8;
}

page.dark .nav-icon {
  opacity: 0.9;
}

/* Dark mode - Tab switch */
page.dark .switch-inner {
  background-color: #2c2c2e;
}

page.dark .switch-btn {
  color: #98989d;
}

page.dark .switch-btn.active {
  background: linear-gradient(135deg, #004d24 0%, #00c853 100%);
  color: #ffffff;
}

/* Dark mode - stats page */
page.dark .header-section,
page.dark .hero-card,
page.dark .category-card,
page.dark .top-item,
page.dark .empty-state,
page.dark .tab-switch {
  background-color: #1e1e20;
}

page.dark .header-title,
page.dark .header-date,
page.dark .hero-label,
page.dark .hero-amount {
  color: #e8e8e8;
}

page.dark .tab-btn {
  color: #98989d;
}

page.dark .tab-btn.active {
  background: linear-gradient(135deg, #004d24 0%, #00c853 100%);
  color: #ffffff;
}

/* Dark mode child elements */
page.dark .stats-row,
page.dark .list-group,
page.dark .list-item,
page.dark .stat-item,
page.dark .picker-modal,
page.dark .picker-row {
  background-color: #1e1e20;
  color: #e8e8e8;
}

page.dark .arrow,
page.dark .footer text,
page.dark .stat-label,
page.dark .picker-label,
page.dark .theme-status {
  color: #98989d;
}

page.dark .list-item {
  border-bottom-color: rgba(255, 255, 255, 0.1);
}

/* Dark mode for index page */
page.dark .summary-card,
page.dark .expiring-card,
page.dark .subscription-item,
page.dark .section,
page.dark .top-nav,
page.dark .item-left,
page.dark .item-right {
  background-color: #1e1e20;
  color: #e8e8e8;
}

page.dark .item-name,
page.dark .item-date,
page.dark .item-price,
page.dark .item-cycle,
page.dark .summary-label,
page.dark .summary-amount,
page.dark .nav-title {
  color: #e8e8e8;
}

page.dark .meta-text,
page.dark .section-title {
  color: #98989d;
}

page.dark .empty {
  color: #98989d;
}

/* Dark mode for add page */
page.dark .search-box,
page.dark .quick-scroll,
page.dark .quick-list,
page.dark .quick-item,
page.dark .nav-spacer {
  background-color: #1e1e20;
}

page.dark .search-input {
  background-color: #1e1e20;
  color: #e8e8e8;
}

page.dark .nav-title,
page.dark .section-title,
page.dark .input-label,
page.dark .picker-value {
  color: #e8e8e8;
}

page.dark .quick-label,
page.dark .placeholder-text {
  color: #98989d;
}

/* Dark mode for stats page */
page.dark .header-section,
page.dark .hero-card,
page.dark .category-card,
page.dark .top-item,
page.dark .empty-state {
  background-color: #1e1e20;
}

page.dark .header-title,
page.dark .header-date,
page.dark .hero-label,
page.dark .hero-amount,
page.dark .tab-btn {
  color: #e8e8e8;
}

/* Dark mode for detail page */
page.dark .header,
page.dark .info-card,
page.dark .progress-section,
page.dark .history-list {
  background-color: #1e1e20;
}

page.dark .service-name,
page.dark .info-label,
page.dark .info-value {
  color: #e8e8e8;
}

/* Dark mode for edit page */
page.dark .cycle-options,
page.dark .input-row,
page.dark .date-row {
  background-color: #1e1e20;
}

.container.dark {
  background-color: var(--surface);
  color: var(--on-surface);
}


.container {
  min-height: 100vh;
  background-color: var(--surface);
  color: var(--on-surface);
  transition: background-color 0.3s ease, color 0.3s ease;
}

/* Global elements */
view, text, scroll-view, input, textarea {
  box-sizing: border-box;
}

input, textarea {
  color: var(--on-surface);
  background-color: var(--surface-container-low);
}

input::placeholder, textarea::placeholder {
  color: var(--on-surface-variant);
}

button {
  color: var(--on-primary);
  background-color: var(--primary);
}

.btn-save {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
  color: var(--on-primary);
}

.summary-card, .expiring-card, .subscription-item, .user-card, .list-group,
.hero-card, .category-card, .top-item, .input-row, .date-row, .toggle-row,
.header, .info-card, .progress-section, .history-list, .reminder-row,
.stats-row, .search-box, .quick-item {
  background-color: var(--surface-container-lowest);
}

.info-card.highlight {
  background-color: rgba(7, 193, 96, 0.1);
}

.section-title, .item-name, .item-price, .stat-num, .stat-label,
.nickname, .user-id, .service-name, .service-price, .header-title,
.hero-amount, .top-name, .top-price, .legend-name, .legend-value,
.nav-title, .progress-label, .history-title, .date-label, .toggle-label,
.reminder-text, .back-icon, .nav-icon {
  color: var(--on-surface);
}

.summary-label, .meta-text, .item-date, .item-cycle, .days-tag,
.billing-cycle, .header-date, .donut-label, .legend-percent,
.progress-text, .meta-item, .history-status-text, .history-date,
.toggle-hint, .nav-cancel, .footer text, .quick-label, .arrow,
.input-label, .cost-prefix, .date-value, .secure-note {
  color: var(--on-surface-variant);
}

.switch-btn.active, .cycle-picker.active, .tab-btn.active {
  background-color: var(--surface-container-lowest);
  color: var(--primary);
}

.progress-bar {
  background-color: var(--surface-container);
}

.progress-fill {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
}

.top-nav, .top-bar, .safe-area-top, .back-btn {
  background-color: var(--surface);
}

.item-logo, .service-logo, .avatar, .quick-logo, .top-logo, .history-icon {
  background-color: var(--surface-container-low);
}

.logo-text {
  color: var(--on-surface-variant);
}

.tab-switch, .cycle-picker-container, .switch-inner, .top-bar-bg, .donut-hole {
  background-color: var(--surface-container-low);
}

.insight-card {
  background-color: var(--insight-bg);
  border-left: 8rpx solid var(--insight-border);
}

.insight-text {
  color: var(--insight-text);
}

.status-tag, .days-tag.safe, .summary-meta {
  background-color: rgba(7, 193, 96, 0.1);
  color: var(--primary-container);
}

.days-tag.urgent {
  background-color: rgba(186, 26, 26, 0.1);
  color: var(--error);
}

.days-tag.warning {
  background-color: rgba(162, 61, 51, 0.1);
  color: var(--tertiary);
}

.meta-dot {
  background-color: var(--primary-container);
}

.trend-badge {
  background-color: rgba(186, 26, 26, 0.1);
}

.trend-icon, .trend-text {
  color: var(--error);
}

.quick-item.selected {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
}

.quick-item.selected .quick-label, .quick-item.selected .quick-initial {
  color: var(--on-primary);
}

.danger-text {
  color: var(--error);
}

.search-box {
  background-color: var(--surface-container-low);
  border-radius: 12px;
}

.search-box.focused {
  background-color: var(--surface-container-lowest);
  border: 1px solid rgba(0, 109, 51, 0.2);
}

.search-clear {
  color: var(--on-surface-variant);
}

.empty, .empty-state, .history-empty {
  color: var(--on-surface-variant);
}

.list-item, .date-picker {
  border-bottom: 1px solid var(--outline-variant);
}

.theme-switch {
  transform: scale(0.9);
}

switch .wx-switch-handle {
  background-color: var(--surface-container-low) !important;
}

switch[checked] .wx-switch-handle {
  background-color: var(--primary-container) !important;
}