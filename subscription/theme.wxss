/* The Fluid Minimalist Design System - Theme Variables */

page {
  --surface: #f9f9fb;
  --surface-container-low: #f3f3f5;
  --surface-container-lowest: #ffffff;
  --surface-container: #eeeef0;
  --surface-container-high: #e8e8ea;
  --on-surface: #1a1c1d;
  --on-surface-variant: #8a8a8a;
  --primary: #006d33;
  --primary-container: #07c160;
  --on-primary: #ffffff;
  --secondary: #2f6a3f;
  --secondary-container: #b1f2bb;
  --tertiary: #a23d33;
  --tertiary-container: #ff8475;
  --error: #ba1a1a;
  --error-container: #ffdad6;
  --outline: #6c7b6c;
  --outline-variant: rgba(26, 28, 29, 0.15);
  --insight-bg: #FFF9E6;
  --insight-border: #FFD54F;
  --insight-text: #7F6000;
  background-color: var(--surface);
  color: var(--on-surface);
  transition: background-color 0.3s ease, color 0.3s ease;
}

.container {
  min-height: 100vh;
  background-color: var(--surface);
  color: var(--on-surface);
  transition: background-color 0.3s ease, color 0.3s ease;
}

/* Global elements */
view, text, scroll-view, input, textarea {
  box-sizing: border-box;
}

input, textarea {
  color: var(--on-surface);
  background-color: var(--surface-container-low);
}

input::placeholder, textarea::placeholder {
  color: var(--on-surface-variant);
}

button {
  color: var(--on-primary);
  background-color: var(--primary);
}

.btn-save {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
  color: var(--on-primary);
}

.summary-card, .expiring-card, .subscription-item, .user-card, .list-group,
.hero-card, .category-card, .top-item, .input-row, .date-row, .toggle-row,
.header, .info-card, .progress-section, .history-list, .reminder-row,
.stats-row, .search-box, .quick-item {
  background-color: var(--surface-container-lowest);
}

.info-card.highlight {
  background-color: rgba(7, 193, 96, 0.1);
}

.section-title, .item-name, .item-price, .stat-num, .stat-label,
.nickname, .user-id, .service-name, .service-price, .header-title,
.hero-amount, .top-name, .top-price, .legend-name, .legend-value,
.nav-title, .progress-label, .history-title, .date-label, .toggle-label,
.reminder-text, .back-icon, .nav-icon {
  color: var(--on-surface);
}

.summary-label, .meta-text, .item-date, .item-cycle, .days-tag,
.billing-cycle, .header-date, .donut-label, .legend-percent,
.progress-text, .meta-item, .history-status-text, .history-date,
.toggle-hint, .nav-cancel, .footer text, .quick-label, .arrow,
.input-label, .cost-prefix, .date-value, .secure-note {
  color: var(--on-surface-variant);
}

.switch-btn.active, .cycle-picker.active, .tab-btn.active {
  background-color: var(--surface-container-lowest);
  color: var(--primary);
}

.progress-bar {
  background-color: var(--surface-container);
}

.progress-fill {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
}

.top-nav, .top-bar, .safe-area-top, .back-btn {
  background-color: var(--surface);
}

.item-logo, .service-logo, .avatar, .quick-logo, .top-logo, .history-icon {
  background-color: var(--surface-container-low);
}

.logo-text {
  color: var(--on-surface-variant);
}

.tab-switch, .cycle-picker-container, .switch-inner, .top-bar-bg, .donut-hole {
  background-color: var(--surface-container-low);
}

.insight-card {
  background-color: var(--insight-bg);
  border-left: 8rpx solid var(--insight-border);
}

.insight-text {
  color: var(--insight-text);
}

.status-tag, .days-tag.safe, .summary-meta {
  background-color: rgba(7, 193, 96, 0.1);
  color: var(--primary-container);
}

.days-tag.urgent {
  background-color: rgba(186, 26, 26, 0.1);
  color: var(--error);
}

.days-tag.warning {
  background-color: rgba(162, 61, 51, 0.1);
  color: var(--tertiary);
}

.meta-dot {
  background-color: var(--primary-container);
}

.trend-badge {
  background-color: rgba(186, 26, 26, 0.1);
}

.trend-icon, .trend-text {
  color: var(--error);
}

.quick-item.selected {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
}

.quick-item.selected .quick-label, .quick-item.selected .quick-initial {
  color: var(--on-primary);
}

.danger-text {
  color: var(--error);
}

.search-box {
  background-color: var(--surface-container-low);
  border-radius: 12px;
}

.search-box.focused {
  background-color: var(--surface-container-lowest);
  border: 1px solid rgba(0, 109, 51, 0.2);
}

.search-clear {
  color: var(--on-surface-variant);
}

.empty, .empty-state, .history-empty {
  color: var(--on-surface-variant);
}

.list-item, .date-picker {
  border-bottom: 1px solid var(--outline-variant);
}