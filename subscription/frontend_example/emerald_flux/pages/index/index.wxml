<!-- index.wxml -->
<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-text">
        <view class="user-name">{{userInfo.nickName || '用户'}}</view>
        <view class="user-subtitle">管理您的订阅</view>
      </view>
    </view>
  </view>

  <!-- 支出统计卡片 -->
  <view class="stats-card">
    <view class="stats-title">本月支出</view>
    <view class="stats-amount">¥{{monthlyTotal}}</view>
    <view class="stats-period">年度共计 ¥{{yearlyTotal}}</view>
    
    <view class="stats-tabs">
      <view 
        class="tab-item {{activeTab === 'month' ? 'active' : 'inactive'}}" 
        bindtap="switchTab" 
        data-type="month">
        本月
      </view>
      <view 
        class="tab-item {{activeTab === 'year' ? 'active' : 'inactive'}}" 
        bindtap="switchTab" 
        data-type="year">
        本年
      </view>
    </view>
  </view>

  <!-- 订阅列表 -->
  <view class="section-header">全部订阅</view>
  
  <view class="subscription-list" wx:if="{{subscriptions.length > 0}}">
    <block wx:for="{{subscriptions}}" wx:key="id">
      <view 
        class="subscription-item {{item.isUrgent ? 'urgent' : ''}}" 
        bindtap="goToDetail" 
        data-id="{{item.id}}">
        <view class="sub-icon">
          <image src="{{item.icon}}" mode="aspectFill" wx:if="{{item.icon}}"></image>
        </view>
        <view class="sub-content">
          <view class="sub-name">{{item.name}}</view>
          <view class="sub-meta">{{item.category}} · 下次: {{item.nextBillingDate}}</view>
        </view>
        <view class="sub-price">
          <view class="price-value">¥{{item.price}}</view>
          <text class="price-period">/{{item.period}}</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-icon"></view>
    <view class="empty-text">暂无订阅记录</view>
  </view>

  <!-- 底部 TabBar -->
  <view class="tab-bar">
    <view class="tab-item-bar">
      <view class="tab-icon"></view>
      <text class="tab-label active">首页</text>
    </view>
    <view class="tab-item-bar" bindtap="goToStatistics">
      <view class="tab-icon"></view>
      <text class="tab-label">统计</text>
    </view>
    <view class="tab-item-bar" bindtap="goToSettings">
      <view class="tab-icon"></view>
      <text class="tab-label">设置</text>
    </view>
  </view>
</view>