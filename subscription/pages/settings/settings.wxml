<view class="container">
  <!-- Stats Overview -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.activeCount}}</text>
      <text class="stat-label">活跃订阅</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">¥{{stats.totalSpent}}</text>
      <text class="stat-label">月总支出</text>
    </view>
  </view>

  <!-- Settings List -->
  <view class="list-group">
    <view class="list-item" bindtap="onExportData">
      <view class="item-left">
        <text class="icon">📤</text>
        <text class="item-text">导出账单</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="list-item" bindtap="onFeedback">
      <view class="item-left">
        <text class="icon">💬</text>
        <text class="item-text">帮助与反馈</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="list-item danger" bindtap="onClearData">
      <view class="item-left">
        <text class="icon">🗑️</text>
        <text class="danger-text">清空所有数据</text>
      </view>
    </view>
  </view>

  <!-- Footer -->
  <view class="footer">
    <text>Version 1.0.4</text>
  </view>

  <!-- Custom Date Picker Modal -->
  <view class="picker-mask" wx:if="{{showDatePicker}}" bindtap="onPickerClose"></view>
  <view class="picker-modal {{showDatePicker ? 'show' : ''}}">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="onPickerClose">取消</text>
      <text class="picker-title">选择日期范围</text>
      <text class="picker-confirm" bindtap="onConfirmDate">确定</text>
    </view>
    <view class="picker-body">
      <view class="picker-row">
        <text class="picker-label">开始日期</text>
        <picker mode="date" value="{{customStartDate}}" start="2020-01-01" end="2099-12-31" bindchange="onStartDateChange">
          <view class="picker-value">{{customStartDate}}</view>
        </picker>
      </view>
      <view class="picker-row">
        <text class="picker-label">结束日期</text>
        <picker mode="date" value="{{customEndDate}}" start="2020-01-01" end="2099-12-31" bindchange="onEndDateChange">
          <view class="picker-value">{{customEndDate}}</view>
        </picker>
      </view>
    </view>
  </view>

  <view class="safe-area"></view>
</view>