/* The Fluid Minimalist Design System */
@import 'theme.wxss';

/* Global Styles */
view, text, scroll-view, input, textarea {
  box-sizing: border-box;
}

/* Root container class */
.container {
  min-height: 100vh;
  background-color: var(--surface);
  color: var(--on-surface);
  transition: all 0.3s ease;
}